{
  "manifest_version": 3,
  "name": "Automatic CX-Bucks",
  "version": "1.0.0",
  "description": "Monitor Kick.com streamers, auto-open tabs, claim bonuses, and engage with chat.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "https://kick.com/*",
    "https://api.kick.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://kick.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
